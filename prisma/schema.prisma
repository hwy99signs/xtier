generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  DRIVER
  ADMIN
}

enum SubscriberStatus {
  PENDING_APPROVAL
  APPROVED
  WAITLISTED
  REJECTED
  SUSPENDED
}

enum DriverStatus {
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  REJECTED
}

enum BookingDirection {
  TO_AIRPORT
  FROM_AIRPORT
  BOTH
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DRIVER_ASSIGNED
  EN_ROUTE
  ARRIVED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  COMMITMENT_PAID
  BALANCE_DUE
  PAID_IN_FULL
  REFUNDED
  FAILED
}

enum ZoneType {
  ORIGIN
  DESTINATION
  BOTH
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriber   Subscriber?
  driver       Driver?

  @@map("users")
}

model Subscriber {
  id              String           @id @default(cuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id])

  // Address info
  pickupAddress   String
  pickupCity      String
  pickupState     String
  pickupZip       String
  dropoffAddress  String           // Usually IAH
  dropoffCity     String
  dropoffState    String
  dropoffZip      String

  // Calculated fields
  distanceMiles   Float?
  estimatedPrice  Float?
  zoneId          String?
  zone            ServiceZone?     @relation(fields: [zoneId], references: [id])

  // Direction preference
  direction       BookingDirection @default(BOTH)

  // Admin workflow
  status          SubscriberStatus @default(PENDING_APPROVAL)
  assignedDriverId String?
  assignedDriver  Driver?          @relation(fields: [assignedDriverId], references: [id])
  adminNotes      String?
  approvedAt      DateTime?
  approvedBy      String?

  // Payment
  paymentStatus   PaymentStatus    @default(UNPAID)
  commitmentPaid  Float?
  balanceDue      Float?
  commitmentPaidAt DateTime?
  balancePaidAt   DateTime?
  stripeCustomerId String?
  stripePaymentId  String?

  // Terms
  termsAcceptanceId String?
  termsAcceptance   TermsAcceptance? @relation(fields: [termsAcceptanceId], references: [id])

  bookings        Booking[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("subscribers")
}

model Driver {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id])

  // Application fields
  licenseNumber   String
  licenseState    String
  licenseExpiry   DateTime
  vehicleMake     String
  vehicleModel    String
  vehicleYear     Int
  vehicleColor    String
  vehiclePlate    String
  vehicleCapacity Int          @default(4)
  yearsExperience Int          @default(0)
  bio             String?

  // Admin workflow
  status          DriverStatus @default(PENDING_REVIEW)
  adminNotes      String?
  approvedAt      DateTime?
  approvedBy      String?
  isAvailable     Boolean      @default(false)

  // Terms
  termsAcceptanceId String?
  termsAcceptance   TermsAcceptance? @relation(fields: [termsAcceptanceId], references: [id])

  subscribers     Subscriber[]
  bookings        Booking[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("drivers")
}

model ServiceZone {
  id          String    @id @default(cuid())
  name        String    // e.g. "Kingwood North", "Atascocita"
  description String?
  type        ZoneType  @default(ORIGIN)
  minMiles    Float     @default(0)
  maxMiles    Float     @default(999)
  basePrice   Float     @default(45)
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)

  subscribers Subscriber[]
  pricingRules PricingRule[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("service_zones")
}

model PricingRule {
  id           String    @id @default(cuid())
  name         String
  description  String?
  zoneId       String?
  zone         ServiceZone? @relation(fields: [zoneId], references: [id])
  direction    BookingDirection @default(BOTH)

  // Pricing components
  baseFare     Float     @default(45)
  perMileRate  Float     @default(2.00)
  surgeMultiplier Float  @default(1.0)
  commitmentPct Float    @default(20) // % of total charged upfront
  minFare      Float     @default(45)
  maxFare      Float?

  isActive     Boolean   @default(true)
  effectiveFrom DateTime @default(now())
  effectiveTo  DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("pricing_rules")
}

model Booking {
  id             String        @id @default(cuid())
  subscriberId   String
  subscriber     Subscriber    @relation(fields: [subscriberId], references: [id])
  driverId       String?
  driver         Driver?       @relation(fields: [driverId], references: [id])

  scheduledAt    DateTime
  direction      BookingDirection
  pickupAddress  String
  dropoffAddress String
  distanceMiles  Float?
  fareAmount     Float?

  status         BookingStatus @default(PENDING)
  paymentStatus  PaymentStatus @default(UNPAID)
  flightNumber   String?
  notes          String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("bookings")
}

model TermsVersion {
  id          String   @id @default(cuid())
  version     String   // e.g. "v1.0", "v1.1"
  title       String
  content     String   @db.Text
  isActive    Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  acceptances TermsAcceptance[]

  @@map("terms_versions")
}

model TermsAcceptance {
  id              String       @id @default(cuid())
  termsVersionId  String
  termsVersion    TermsVersion @relation(fields: [termsVersionId], references: [id])

  // Who accepted
  email           String
  ipAddress       String?
  userAgent       String?
  acceptedAt      DateTime     @default(now())

  // Individual checkbox responses (stored as JSON for audit)
  checkboxResponses Json

  subscriberLinks Subscriber[]
  driverLinks     Driver[]

  @@map("terms_acceptances")
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  label     String
  groupKey  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_settings")
}
