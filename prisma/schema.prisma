generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String
  role         String      @default("CUSTOMER")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  driver       Driver?
  subscriber   Subscriber?
  sentMessages     ChatMessage[] @relation("SentMessages")
  receivedMessages ChatMessage[] @relation("ReceivedMessages")

  @@map("users")
}

model Subscriber {
  id                  String           @id @default(cuid())
  userId              String           @unique
  pickupAddress       String
  pickupCity          String
  pickupState         String
  pickupZip           String
  dropoffAddress      String
  dropoffCity         String
  dropoffState        String
  dropoffZip          String
  distanceMiles       Float?
  estimatedPrice      Float?
  zoneId              String?
  direction           String           @default("BOTH")
  employerName        String?
  shiftType           String?
  serviceType         String           @default("COMMUTER")
  daysPerWeek         Int              @default(5)
  preferredPickupTime String?
  preferredReturnTime String?
  startDate           DateTime?
  notes               String?
  status              String           @default("PENDING_APPROVAL")
  assignedDriverId    String?
  adminNotes          String?
  approvedAt          DateTime?
  approvedBy          String?
  paymentStatus       String           @default("UNPAID")
  commitmentPaid      Float?
  balanceDue          Float?
  commitmentPaidAt    DateTime?
  balancePaidAt       DateTime?
  stripeCustomerId    String?
  stripePaymentId     String?
  termsAcceptanceId   String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  bookings            Booking[]
  user                User             @relation(fields: [userId], references: [id])
  zone                ServiceZone?     @relation(fields: [zoneId], references: [id])
  assignedDriver      Driver?          @relation(fields: [assignedDriverId], references: [id])
  termsAcceptance     TermsAcceptance? @relation(fields: [termsAcceptanceId], references: [id])

  @@map("subscribers")
}

model Driver {
  id                String           @id @default(cuid())
  userId            String           @unique
  licenseNumber     String
  licenseState      String
  licenseExpiry     DateTime
  vehicleMake       String
  vehicleModel      String
  vehicleYear       Int
  vehicleColor      String
  vehiclePlate      String
  vehicleCapacity   Int              @default(4)
  yearsExperience   Int              @default(0)
  bio               String?
  status            String           @default("PENDING_REVIEW")
  adminNotes        String?
  approvedAt        DateTime?
  approvedBy        String?
  isAvailable       Boolean          @default(false)
  termsAcceptanceId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  bookings          Booking[]
  user              User             @relation(fields: [userId], references: [id])
  termsAcceptance   TermsAcceptance? @relation(fields: [termsAcceptanceId], references: [id])
  subscribers       Subscriber[]

  @@map("drivers")
}

model ServiceZone {
  id           String        @id @default(cuid())
  name         String
  description  String?
  type         String        @default("ORIGIN")
  minMiles     Float         @default(0)
  maxMiles     Float         @default(999)
  basePrice    Float         @default(45)
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pricingRules PricingRule[]
  subscribers  Subscriber[]

  @@map("service_zones")
}

model PricingRule {
  id              String       @id @default(cuid())
  name            String
  description     String?
  zoneId          String?
  direction       String       @default("BOTH")
  baseFare        Float        @default(45)
  perMileRate     Float        @default(2.00)
  surgeMultiplier Float        @default(1.0)
  commitmentPct   Float        @default(20)
  minFare         Float        @default(45)
  maxFare         Float?
  isActive        Boolean      @default(true)
  effectiveFrom   DateTime     @default(now())
  effectiveTo     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  zone            ServiceZone? @relation(fields: [zoneId], references: [id])

  @@map("pricing_rules")
}

model Booking {
  id             String     @id @default(cuid())
  subscriberId   String
  driverId       String?
  scheduledAt    DateTime
  direction      String
  pickupAddress  String
  dropoffAddress String
  distanceMiles  Float?
  fareAmount     Float?
  status         String     @default("PENDING")
  paymentStatus  String     @default("UNPAID")
  flightNumber   String?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  subscriber     Subscriber @relation(fields: [subscriberId], references: [id])
  driver         Driver?    @relation(fields: [driverId], references: [id])

  @@map("bookings")
}

model TermsVersion {
  id          String            @id @default(cuid())
  version     String
  title       String
  content     String
  isActive    Boolean           @default(false)
  publishedAt DateTime          @default(now())
  createdAt   DateTime          @default(now())
  acceptances TermsAcceptance[]

  @@map("terms_versions")
}

model TermsAcceptance {
  id                String       @id @default(cuid())
  termsVersionId    String
  email             String
  ipAddress         String?
  userAgent         String?
  acceptedAt        DateTime     @default(now())
  checkboxResponses Json
  driverLinks       Driver[]
  subscriberLinks   Subscriber[]
  termsVersion      TermsVersion @relation(fields: [termsVersionId], references: [id])

  @@map("terms_acceptances")
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String
  groupKey  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_settings")
}

model AuditLog {
  id           String   @id @default(cuid())
  adminId      String?
  adminName    String?
  action       String
  targetEntity String?
  targetId     String?
  previousData Json?
  newData      Json?
  createdAt    DateTime @default(now())

  @@map("audit_logs")
}
model ChatMessage {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  receiverId String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@map("chat_messages")
}
